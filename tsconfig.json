{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "resolveJsonModule": true,
    "types": ["chrome"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["tests/**/*.ts", "dist", "node_modules"]
}
